{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/pm-hook.sh\" session-start",
            "timeout": 10000,
            "statusMessage": "Loading project state..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/pm-hook.sh\" pre-compact",
            "timeout": 10000,
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/pm-hook.sh\" task-completed",
            "timeout": 10000,
            "async": true
          }
        ]
      }
    ]
  }
}
